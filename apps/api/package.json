{
  "name": "@member-platform/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "pnpm build && node dist/apps/api/src/main.js",
    "build": "pnpm prisma:generate && nest build",
    "start": "node dist/apps/api/src/main.js",
    "lint": "echo api-lint-skip",
    "test": "jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
