API_PORT=3000
API_HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:password@localhost:5432/member_platform?schema=public

# 认证密钥 — 生产环境必须更改为随机字符串
JWT_SECRET=change-me-to-a-random-string

# 管理后台登录密码
ADMIN_PASSWORD=your-admin-password

# CORS 允许的来源（逗号分隔），留空则允许所有来源
# 示例: CORS_ORIGIN=https://admin.example.com,https://www.example.com
# CORS_ORIGIN=

# 微信小程序登录模式
# mock = 本地开发用模拟数据，不调用真实微信 API
# real = 生产环境，调用真实微信 API
MINIAPP_LOGIN_MODE=mock
MINIAPP_MOCK_OPEN_ID=mock-openid-local-user
MINIAPP_MOCK_PHONE=13800138000

# 上线时改为 real 模式，并填写微信小程序后台的 AppID/AppSecret
# MINIAPP_LOGIN_MODE=real
# WECHAT_MINIAPP_APP_ID=
# WECHAT_MINIAPP_APP_SECRET=
