# Copy this file to .env.production and fill in real values.
# .env.production is gitignored — never commit secrets.

# Database password (any strong password)
DB_PASSWORD=change_me_strong_db_password

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=change_me_random_64_chars

# Admin login password
ADMIN_PASSWORD=change_me_admin_password

# CORS allowed origins (comma-separated). Empty = allow all.
CORS_ORIGIN=

# WeChat MiniProgram credentials (from mp.weixin.qq.com)
WECHAT_MINIAPP_APP_ID=your_wx_app_id
WECHAT_MINIAPP_APP_SECRET=your_wx_app_secret
